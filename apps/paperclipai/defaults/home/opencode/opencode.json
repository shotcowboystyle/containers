{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "external_directory": {
      "/**": "allow"
    }
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (homelab)",
      "options": {
        "baseURL": "http://ollama.ai.svc.cluster.local:11434/v1"
      },
      "models": {
        "minimax-m2.7:cloud": {
          "name": "minimax-m2.7:cloud"
        },
        "kimi-k2.6:cloud": {
          "name": "kimi-k2.6:cloud"
        },
        "qwen3.5:cloud": {
          "name": "qwen3.5:cloud"
        },
        "qwen2.5:7b": {
          "name": "qwen2.5:7b"
        },
        "gemma4:e4b": {
          "name": "gemma4:e4b"
        },
        "phi4-mini:3.8b": {
          "name": "phi4-mini:3.8b"
        },
        "deepseek-r1:8b": {
          "name": "deepseek-r1:8b"
        },
        "mistral:7b": {
          "name": "mistral:7b"
        }
      }
    }
  }
}